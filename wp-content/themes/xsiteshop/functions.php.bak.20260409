	include $_SERVER['DOCUMENT_ROOT']."/wp-content/themes/xsiteshop/load/admin/".$name.".php";
}


// Функция очистки всего кеша

function xs_clear_cache($clean_image = false)
{
	if(current_user_can('administrator'))
	{
		$dir = $_SERVER['DOCUMENT_ROOT'].'/wp-content/uploads/xs_cache/pages';
	
		if ($objs = glob($dir."/*")) 
			foreach($objs as $obj) 
				if(!is_dir($obj)) unlink($obj);
				
		if($clean_image)
		{
			$dir = $_SERVER['DOCUMENT_ROOT'].'/wp-content/uploads/xs_cache/watermark';
		
			if ($objs = glob($dir."/*")) 
				foreach($objs as $obj) 
					if(!is_dir($obj)) unlink($obj); 

			$dir = $_SERVER['DOCUMENT_ROOT'].'/wp-content/uploads/xs_cache/resize_img';
		
			if ($objs = glob($dir."/*")) 
				foreach($objs as $obj) 
					if(!is_dir($obj)) unlink($obj);
		}
	}
}


