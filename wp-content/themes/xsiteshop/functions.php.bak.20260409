// Отключаем вывод товаров с меткой Топ категорий

function xs_filter_products($wp_query) 
{
	global $wpdb, $big_data;
	

	// Получаем список категорий, товары которых нужно скрыть с сайта

	if(!isset($big_data['categories_hide_product']))
	{
		$big_data['categories_hide_product'] = [];
		
		$categories_hide_product = get_terms(array(
			'taxonomy'		=> 'product_cat',
			'count'			=> false,
			'meta_query'	=> [
				[
					'key' => 'is_product_hide',
					'value' => 'y'
				]
			]
		));
		
		foreach($categories_hide_product as $v)
			$big_data['categories_hide_product'][] = $v->term_id;
	}

	$ar_not_product_in_term = [];
	
	if(isset($big_data['categories_hide_product']) && count($big_data['categories_hide_product']))
		$ar_not_product_in_term = [
			'taxonomy' => 'product_cat',
			'field' => 'id',
			'operator' => 'NOT IN',
			'terms' => $big_data['categories_hide_product']
		];
	
	//echo $wp_query->get('post_type');
	
	if(
		!is_admin() && 
		(
			$wp_query->get('post_type') == 'product' || 
			(
				$wp_query->is_main_query() && 
				isset($wp_query->query_vars['product_cat']) && 
				!is_product()
			)
		)
	)
	{
		$ar_meta_query_stock = [
			'key' => '_stock_status',
			'value' => 'instock'
		];
		
		$meta_query = $wp_query->get('meta_query');
		
		if(is_array($meta_query))
		{
			$is_set = true;
			
			foreach($meta_query as $v)
				if(isset($v['key']) && $v['key'] == '_stock_status' && isset($v['value']) && $v['value'] == 'instock')
					$is_set = false;
			
			if($is_set)
				$meta_query[] = $ar_meta_query_stock;
		}
		else
			$meta_query = [$ar_meta_query_stock];
		
		//pre($meta_query);
		
		$wp_query->set('meta_query', $meta_query);
	}	

	
	if(!is_admin() && $wp_query->is_main_query() && isset($wp_query->query_vars['product_cat']) && !is_product()) 
	{
		$tax_query = $wp_query->get('tax_query');
		
		if($tax_query && !empty($tax_query) && is_array($tax_query))
		{
			$category = get_queried_object();
			
			
			if($category->term_id == $big_data['special_term_id'])
			{
				$_tax_query = [
					[
						'taxonomy' => 'product_tag',
						'field' => 'id',
						'terms' => 357
					],
				];
			
				if(count($ar_not_product_in_term))
					$_tax_query[] = $ar_not_product_in_term;
					
				$arg = array( 
					'tax_query' => $_tax_query, 
					'posts_per_page' => 99,
					'post_type' => 'product',
				);
			}
			elseif($category->term_id == $big_data['mother_term_id'])
			{
				$_tax_query = [
					[
						'taxonomy' => 'product_tag',
						'field' => 'id',
						'terms' => 367
					],
				];
			
				if(count($ar_not_product_in_term))
					$_tax_query[] = $ar_not_product_in_term;
					
				$arg = array( 
					'tax_query' => $_tax_query, 
					'posts_per_page' => 99,
					'post_type' => 'product',
				);
			}
			else
			{
				$_tax_query = [
					[
						'taxonomy' => 'product_tag',
						'field' => 'id',
						'terms' => 291
					],
				];

				if(count($ar_not_product_in_term))
					$_tax_query[] = $ar_not_product_in_term;
					
				$arg = array( 
					'tax_query' => $_tax_query, 
					'meta_query' => [
						[
							'key' => '_yoast_wpseo_primary_product_cat',
							'value' => $category->term_id
						],
						[
							'key' => '_stock_status',
							'value' => 'instock'
						],
					],
					'posts_per_page' => 99,
					'post_type' => 'product',
				);
			}

			if($category->term_id != $big_data['flowers_instock_term_id'])
			{
				$top_products = new WP_Query($arg);
				
				if($top_products->have_posts())
				{
					while($top_products->have_posts())
					{
						$top_products->the_post();
						global $product;
						$big_data['top_products'][] = $product->get_id();
					}
				}
			}

			if($category->term_id == $big_data['flowers_instock_term_id'])
			{
				$wp_query->set('product_cat', '');
				$wp_query->set('queried_object', []);
				$wp_query->set('queried_object_id', '');
				$wp_query->set('post_type', 'product');
				$wp_query->set('query', []);

				$tax_query[] = [
					'taxonomy' => 'product_tag',
					'field' => 'id',
					'terms' => 328,
					'operator' => 'NOT IN'
				];
				
				$meta_query = $wp_query->get('meta_query');
				
				if(is_array($meta_query))
					$meta_query = [];
				
				foreach($meta_query as $k => $v)
					if($v['key'] == '_stock_status')
						unset($meta_query[$k]);
			
				$meta_query['flowers_instock'] = [
					[
						'key' => '_is_flowers_instock',
						'value' => 'y',
						'compare' => '='
					]
				];
				
				$wp_query->set('meta_query', $meta_query);
			}
			elseif($category->term_id == $big_data['special_term_id'])
			{	
				$wp_query->set('product_cat', '');
				$wp_query->set('queried_object', []);
				$wp_query->set('queried_object_id', '');
				$wp_query->set('post_type', 'product');
				$wp_query->set('query', []);

				$tax_query[] = [
					'taxonomy' => 'product_tag',
					'field' => 'id',
					'terms' => 328,
					'operator' => 'NOT IN'
				];
				
				$meta_query = $wp_query->get('meta_query');
				
				$meta_query[] = [
					[
						'key' => '_size_sale',
						'value' => xs_get_option('xs_price_cpecial'),
						'compare' => '>=',
						'type' => 'NUMERIC'
					]
				];
				
				$wp_query->set('meta_query', $meta_query);
			}
			elseif($category->term_id == 413)
			{
				$tax_query = [];
				$wp_query->set('product_cat', '');
				$wp_query->set('queried_object', []);
				$wp_query->set('queried_object_id', '');
				$wp_query->set('post_type', 'product');
				$wp_query->set('query', []);
				
				$meta_query = $wp_query->get('meta_query');
				$meta_query[] = [
					[
						'key' => 'top_category',
						'value' => '"413"',
						'compare' => 'LIKE'
					]
				];
				
				$wp_query->set('meta_query', $meta_query);
				$big_data['top_products'] = [];
			}
			else
			{
				$tax_query[] = [
					'taxonomy' => 'product_tag',
					'field' => 'id',
					'terms' => 328,
					'operator' => 'NOT IN'
				];
			}
			
			if(count($ar_not_product_in_term))
				$tax_query[] = $ar_not_product_in_term;
			
			$wp_query->set('tax_query', $tax_query);
			
			if(isset($big_data['top_products']) && count($big_data['top_products']) > 0)
				$wp_query->set('post__not_in', $big_data['top_products']);
			
			if(is_super_admin())
				$wp_query->set('post_status', $big_data['admin_product_status']);
		}
	}
	elseif(!is_admin() && count($ar_not_product_in_term) && $wp_query->get('post_type') == 'product')
	{
		$tax_query = $wp_query->get('tax_query');
		
		if(is_array($tax_query))
			$tax_query[] = $ar_not_product_in_term;
		else
			$tax_query = [$ar_not_product_in_term];
		
		$wp_query->set('tax_query', $tax_query);
	}
}


