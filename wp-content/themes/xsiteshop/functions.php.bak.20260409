}

// Сортируем id товаров моего склада в порядке убывания

function sort_ms_ids($ms_ids = "")
{
	if(isset($ms_ids) && !empty($ms_ids))
	{
		$ar_component_ids = [];
		
		$e = explode(",", $ms_ids);
		
		foreach($e as $v)
		{
			$_e = explode(" ", $v);
			
			foreach($_e as $_v)
				if(!empty(trim($_v)))
					$ar_component_ids[] = trim($_v);
		}
			
		$ar_component_ids = array_unique($ar_component_ids);
		
		arsort($ar_component_ids);
		
		$ms_ids = implode(", ", $ar_component_ids);
	}
	
	return $ms_ids;
}

function wpassist_remove_block_library_css()
{
	wp_dequeue_style('wp-block-library');
