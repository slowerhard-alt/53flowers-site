// Получение данных woocommerce

add_action('xs_template_init', 'xs_woocommerce_init');

function xs_woocommerce_init()
{
	global $big_data, $woocommerce, $wpdb;
	
	$big_data['cart']['count'] = count($woocommerce->cart->cart_contents);
	
	if($big_data['cart']['count'] > 0)
		$big_data['cart']['subtotal'] = $woocommerce->cart->get_cart_subtotal();
	
	$big_data['cart']['url'] = wc_get_checkout_url();	


	// Получаем дерево категорий в глобальный массив

	$categories = get_terms(array(
		'taxonomy'		=> 'product_cat',
		'count'			=> false,
		'hide_empty'    => false,
		'exclude'		=> 225,
		'meta_query'	=> [
			'relation' => 'OR',
			[
				'key' => 'is_hide',
				'value' => 'y',
				'compare' => '!='
			],
			[
				'key' => 'is_hide',
				'compare' => 'NOT EXISTS'
			]
		]
	));
	
	foreach($categories as $v)
	{
		if($v->term_id != $big_data['flowers_instock_term_id'] || is_user_logged_in())
			$big_data['categories'][$v->term_id] = $v;
	}


	// Получаем дерево атрибута Размер в глобальный массив

	$sizes = get_terms(array(
		'taxonomy'		=> [], //['pa_kolichestvo', 'pa_razmer', 'pa_vysota'],
		'count'			=> false,
		'hide_empty'    => false,
	));
	
	foreach($sizes as $v)
		$big_data['sizes'][$v->slug] = $v;
		
		
	// Выводим уведомление о новом отзыве в карточке товара

	if(is_product() && isset($_GET['unapproved']))
	{
		wc_add_notice("Ваш отзыв принят, спасибо. Он будет опубликован после проверки администратором.");
	}

	$big_data['is_front_page'] = is_front_page();
}
		
		
