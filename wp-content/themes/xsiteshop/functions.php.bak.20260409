// Работа с датами

function xs_date($date, $show_month_text = true, $show_time = false, $delimiter_time = " в ")
{
	$month_label = array(
		0 => "-",
		1 => "Января",
		2 => "Февраля",
		3 => "Марта",
		4 => "Апреля",
		5 => "Мая",
		6 => "Июня",
		7 => "Июля",
		8 => "Августа",
		9 => "Сентября",
		10 => "Октября",
		11 => "Ноября",
		12 => "Декабря"
	);
	
	if($show_month_text)
		$d = date("j", strtotime ($date))." ".$month_label[(int)date("m", strtotime ($date))]." ".date("Y", strtotime ($date));
	else
		$d = date("j.m.Y", strtotime ($date));
	
	if($show_time)
		$d .= $delimiter_time.date("H:i", strtotime ($date));
	
	return $d;
}	


// Обрезаем строку 

function xs_substr($string, $maxlen, $end = "...")
{
    $cutStr = (mb_strlen(strip_tags($string), 'utf-8') > $maxlen)
        ? mb_substr(strip_tags($string), 0, $maxlen, 'utf-8')
        : $string;
    
	return (mb_strlen(strip_tags($string), 'utf-8') > $maxlen) ? $cutStr.$end : $cutStr;
}


// Запускаем сессии

function start_session() 
{
	if(!session_id())
		session_start();
}


// Выдаем системные сообщения

function xs_get_message()
{
	start_session();
	
	global $xs_error, $xs_good, $error;

	if(isset($error) && is_wp_error($error))
		$_SESSION['XS_MESSAGES']['error'][] = $error->get_error_message();

	if(isset($xs_error) && is_array($xs_error) && count($xs_error) > 0)
		foreach($xs_error as $v)
			$_SESSION['XS_MESSAGES']['error'][] = $v;

	if(isset($xs_good) && is_array($xs_good) && count($xs_good) > 0)
		foreach($xs_good as $v)
			$_SESSION['XS_MESSAGES']['good'][] = $v;

	if(isset($_SESSION['XS_MESSAGES']) && is_array($_SESSION['XS_MESSAGES']) && count($_SESSION['XS_MESSAGES']) > 0)
	{
		foreach($_SESSION['XS_MESSAGES'] as $type => $ar_messages)
		{
			if(is_array($ar_messages) && count($ar_messages) > 0)
			{
				?><div class="xs_info_message <?=$type ?>">
					<div class="container"><?
				
						foreach($ar_messages as $k => $message)
						{
							?><p><?=nl2br($message) ?></p><?
							
							unset($_SESSION['XS_MESSAGES'][$type][$k]);
						}
						
						?><button type="button" class="notice-dismiss" onclick="jQuery(this).parents('.xs_info_message').remove();actual_top_report()"><span class="screen-reader-text">Скрыть это уведомление</span></button>
					</div>
				</div><?
			}
		}			
	}
}


// Фиксируем уведомления

function message($text, $type = "good")
{
	start_session();
	
	if(!isset($_SESSION['XS_MESSAGES'][$type]) || !in_array($text, $_SESSION['XS_MESSAGES'][$type]))
		$_SESSION['XS_MESSAGES'][$type][] = $text;
}


function get_svg($name, $color = "#000", $return = "echo")
{
	if($return == "text")
		return file_get_contents($_SERVER['DOCUMENT_ROOT']."/wp-content/themes/xsiteshop/templates/icons/".$name.".php", true);
	else
		include $_SERVER['DOCUMENT_ROOT']."/wp-content/themes/xsiteshop/templates/icons/".$name.".php";
}


