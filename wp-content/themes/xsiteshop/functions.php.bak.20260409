// Отправка сообщений в телеграм
	
function message_to_telegram($text, $chat_id = -4730974561)
{
	// чтобы узнать chat_id: https://api.telegram.org/bot7855068396:AAGP3qUu3lN1BsDC800AyT4THo14TFtbVd0/getUpdates
	
	//$chat_id = 290920582; // simanov_al
	//$chat_id = 102357228; // hardnex, Александр
	//$chat_id = -4730974561; // Группа
	
	if(!$chat_id)
		return false;
	
	$text = str_replace(
		[
			"_",
			"*",
			"[",
			"]",
			"{",
			"}",
			"`",
			"|",
			"=",
			"#",
			">",
			"~",
			"!",
		], 
		[
			"\\_",
			"\\*",
			"\\[",
			"\\]",
			"\\{",
			"\\}",
			"\\`",
			"\\|",
			"\\=",
			"\\#",
			"\\>",
			"\\~",
			"\\!",
		], 
		$text
	);
	
	$ch = curl_init('https://api.telegram.org/bot7855068396:AAGP3qUu3lN1BsDC800AyT4THo14TFtbVd0/sendMessage');
	curl_setopt_array($ch, array(
		CURLOPT_RETURNTRANSFER => true,
		CURLOPT_POST => true,
		CURLOPT_HEADER => false,
		CURLOPT_HTTPHEADER => array(
			'Host: api.telegram.org',
			'Content-Type: multipart/form-data'
		),
		CURLOPT_POSTFIELDS => array(
			'chat_id' => $chat_id, 
			'text' => $text,
		),
		CURLOPT_TIMEOUT => 0,
		CURLOPT_CONNECTTIMEOUT => 6000,
		CURLOPT_SSL_VERIFYPEER => false
	));
	$r = curl_exec($ch);
	curl_close($ch);
	
	$r = json_decode($r, true);
	
	if(is_array($r) && isset($r['ok']) && $r['ok'])
		return true;
	else
		return false;
}
	
