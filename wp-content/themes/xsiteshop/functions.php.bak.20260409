function pre($ar)
{
	echo "<pre>";
	print_r($ar);
	echo "</pre>";
}


function is($v)
{
	if(!isset($v))
		return false;
	
	if(is_string($v))
		$v = trim($v);
	
	if(!empty($v))
		return true;
	else
		return false;
}


// Работа с get параметрами

function setUrl($url, $varname, $value) // substitute get parameter
{
	 if (is_array($varname)) {
		 foreach ($varname as $i => $n) {
			$v = (is_array($value))
				  ? ( isset($value[$i]) ? $value[$i] : NULL ) 
				  : $value;
			$url = setUrl($url, $n, $v);
		 }
		 return $url;
	 }
	 
	preg_match('/^([^?]+)(\?.*?)?(#.*)?$/', $url, $matches);
	$gp = (isset($matches[2])) ? $matches[2] : ''; // GET-parameters
	if (!$gp) return $url."?".$varname."=".$value;
	
	$pattern = "/([?&])$varname=.*?(?=&|#|\z)/";
	if (preg_match($pattern, $gp)) {
		$substitution = ($value !== '') ? "\${1}$varname=" . preg_quote($value) : '';
		$newgp = preg_replace($pattern, $substitution, $gp); // new GET-parameters
		$newgp = preg_replace('/^&/', '?', $newgp); 
	}
	else    {
		$s = ($gp) ? '&' : '?';
		$newgp = $gp.$s.$varname.'='.$value;
	}
   
	$anchor = (isset($matches[3])) ? $matches[3] : '';
	$newurl = $matches[1].$newgp.$anchor;
	return $newurl;
}


// Очистка строки от лишнего кода

function xs_format_string($x)
{
	$x = trim($x);
	$x = stripslashes($x);
	$x = htmlspecialchars($x);
	$x = addslashes($x);
	
	return $x;
}

function xs_format($text)
{
	if(is_array($text))
	{
		foreach($text as $key => $val)
		{
			if(is_array($val))
			{
				$text[$key] = xs_format($val);
			}
			else
				$text[$key] = xs_format_string($val);
		}
	}
	else
		$text = xs_format_string($text);
	
	return $text;
}


// Склонение существительных после чисел

function format_by_count($count, $form1, $form2, $form3) 
{
	$count = abs($count) % 100;
	$lcount = $count % 10;
	if ($count >= 11 && $count <= 19) return($form3);
	if ($lcount >= 2 && $lcount <= 4) return($form2);
	if ($lcount == 1) return($form1);
	return $form3;
}


