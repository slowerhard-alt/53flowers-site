						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[hide_quantity_in_product]" value="y"<?=is_row('hide_quantity_in_product') ? ' checked' : '' ?> /> Скрыть количество в карточке товара</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[is_fresh_delivery]" value="y"<?=is_row('is_fresh_delivery') ? ' checked' : '' ?> /> Учитывать для «свежая поставка»</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[favorite]" value="y"<?=is_row('favorite') ? ' checked' : '' ?> /> Избранное</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[ms_ids]" value="y"<?=is_row('ms_ids') ? ' checked' : '' ?> /> ID МС</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[ms_is_update_price]" value="y"<?=is_row('ms_is_update_price') ? ' checked' : '' ?> /> Обновлять себестоимость с МС</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[ms_is_update_days]" value="y"<?=is_row('ms_is_update_days') ? ' checked' : '' ?> /> Обновлять дни с МС</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[ms_quantity_for_days]" value="y"<?=is_row('ms_quantity_for_days') ? ' checked' : '' ?> /> Остаток, при котором перестают обновляться дни</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[ms_percent_outstock]" value="y"<?=is_row('ms_percent_outstock') ? ' checked' : '' ?> /> Процент, прибавляемый при нулевом остатке</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[ms_is_update_retail_price]" value="y"<?=is_row('ms_is_update_retail_price') ? ' checked' : '' ?> /> Обновлять розничную цену в МС</label>
						<? 
						
						for($i = 0; $i < $big_data['store_competitors_count']; $i++)
