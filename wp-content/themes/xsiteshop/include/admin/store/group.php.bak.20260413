						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[sale_min_days]" value="y"<?=is_row('sale_min_days') ? ' checked' : '' ?> /> Мин. дней для активации скидки</label>
						
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[forced_price]" value="y"<?=is_row('forced_price') ? ' checked' : '' ?> /> Приор цена</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[sale_forced_price]" value="y"<?=is_row('sale_forced_price') ? ' checked' : '' ?> /> Приоритетная цена без скидки</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[is_set_forced_price]" value="y"<?=is_row('is_set_forced_price') ? ' checked' : '' ?> /> Дни влияют на приоритетную цену</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[price]" value="y"<?=is_row('price') ? ' checked' : '' ?> /> Цена</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[sale_price]" value="y"<?=is_row('sale_price') ? ' checked' : '' ?> /> Цена без скидки</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[color]" value="y"<?=is_row('color') ? ' checked' : '' ?> /> Цвет фона в отчёте</label>
