				<a href="<?=setUrl($big_data['current_url'], 'action', $xs_data->action == 'view' ? 'edit' : 'view') ?>" class="button"><?=$xs_data->action == 'view' ? 'Режим редактирования' : 'Режим просмотра' ?></a>
