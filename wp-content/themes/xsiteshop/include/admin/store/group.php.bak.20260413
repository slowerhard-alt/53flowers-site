					<div class="xs_filter__cols-items">
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[sort]" value="y"<?=is_row('sort') ? ' checked' : '' ?> /> Сорт</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[name]" value="y"<?=is_row('name') ? ' checked' : '' ?> /> Название</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[name_for_user]" value="y"<?=is_row('name_for_user') ? ' checked' : '' ?> /> Название для покупателей</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[category_id]" value="y"<?=is_row('category_id') ? ' checked' : '' ?> /> Категория</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[purchase_price]" value="y"<?=is_row('purchase_price') ? ' checked' : '' ?> /> Закуп цена</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[original_price]" value="y"<?=is_row('original_price') ? ' checked' : '' ?> /> Себес</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[ms_quantity]" value="y"<?=is_row('ms_quantity') ? ' checked' : '' ?> /> Остаток</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[days]" value="y"<?=is_row('days') ? ' checked' : '' ?> /> Дни</label>
						<label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[coefficient]" value="y"<?=is_row('coefficient') ? ' checked' : '' ?> /> Коэффициент</label>
