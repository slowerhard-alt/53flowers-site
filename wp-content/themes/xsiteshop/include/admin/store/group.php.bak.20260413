							$code = 'competitor_'.$i;
							
							?><label class="xs_filter__cols-item"><input form="set_rows" type="checkbox" name="row[<?=$code ?>]" value="y"<?=is_row($code) ? ' checked' : '' ?> /> <?=xs_get_option('xs_competitor_'.$i) ?></label><?
