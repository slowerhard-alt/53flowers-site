	</td><?
}


for($i = 0; $i < $big_data['store_competitors_count']; $i++)
{
	if(!is_row('competitor_'.$i))
		continue;

	$competitor = isset($ar_competitors[$i])
		? $ar_competitors[$i]
		: false;
	
	if(!isset($competitor['p']))
		$competitor['p'] = 0;
	
	?><td>
		<span class="store_row_show">
			<?=$competitor['p'] > 0 ? wc_price($competitor['p']) : "" ?><?
			
			if(isset($competitor['l']) && !empty($competitor['l']))
			{
				?>&nbsp;<a href="<?=$competitor['l'] ?>" target="_blank" class="store_row_competitor_link">***</a><?
			}
			
		?></span>
		<span class="store_row_edit">
			<input type="number" class="store_input_competitor" min="0" step="1" name="c[<?=$v->id ?>][competitors][<?=$i ?>]" value="<?=$competitor['p'] ?>" />&nbsp;<a href="<?=$competitor['l'] ?>" target="_blank" class="store_row_competitor_link">***</a>
		</span>
	</td><?
}				
