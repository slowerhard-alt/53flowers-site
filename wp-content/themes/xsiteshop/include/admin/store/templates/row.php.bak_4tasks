<?
global $big_data;

$coefficient = get_store_coefficient($v->group_id, $v->days);
if(!isset($coefficient['c']))		
	$coefficient['c'] = xs_get_option('xs_store_'.$v->group_id.'_color');

$ar_competitors = json_decode($v->competitors, true);

$is_group = isset($v->is_group) && $v->is_group == 'y';

if(is_row('sort'))
{
	if($is_group)
	{
		?><td>
			<span class="store_row_value"><?=$v->sort ?></span>
		</td><?
	}
	else
	{
		?><td>
			<span class="store_row_show"><?=$v->sort ?></span>
			<span class="store_row_edit"><input type="number" class="store_input_sort" min="0" step="1" name="c[<?=$v->id ?>][sort]" value="<?=$v->sort ?>" /></span>
		</td><?
	}
}

if(is_row('category_id'))
{
	?><td <?=!empty($v->color) && $v->color != "#ffffff" ? 'style="background:'.$v->color.'"' : '' ?>>
		<span class="store_row_show"><?=$v->category_name ?></span>
		<span class="store_row_edit">
			<select name="c[<?=$v->id ?>][category_id]" class="store_input_category_id"><?
				
				foreach($big_data['category_list_all'] as $_k => $_v) 
				{
					?><option value="<?=$_k ?>"<?=$_k == $v->category_id ? " selected" : ""?>><?=$_v ?></option><?
				}
			
			?></select>
	</td><?
}

if(is_row('name'))
{
	if($is_group)
	{
		?><td <?=!empty($v->color) && $v->color != "#ffffff" ? 'style="background:'.$v->color.'"' : '' ?>>
			<div class="store_row_long">
				<span class="store_row_value">
					<a class="xs_image_link" target="_blank" data-modal="group-detail" data-id="<?=$v->id ?>" href="#">
						<span class="name"><?=$v->name ?></span>
					</a>
				</span>
			</div>
		</td><?
	}
	else
	{
		?><td <?=!empty($v->color) && $v->color != "#ffffff" ? 'style="background:'.$v->color.'"' : '' ?>>
			<div class="store_row_long">
				<span class="store_row_show">
					<a class="xs_image_link" target="_blank" href="/wp-admin/admin.php?page=store&section=detail&id=<?=$v->id ?>">
						<span class="name"><?=$v->name ?></span>
					</a>
				</span>
				<span class="store_row_edit"><input type="text" class="store_input_name" name="c[<?=$v->id ?>][name]" value="<?=$v->name ?>" /></span>
			</div>
		</td><?
	}
}

if(is_row('name_for_user'))
{
	?><td <?=!empty($v->color) && $v->color != "#ffffff" ? 'style="background:'.$v->color.'"' : '' ?>>
		<div class="store_row_long">
			<span class="store_row_show"><?=$v->name_for_user ?></span>
			<span class="store_row_edit"><input type="text" class="store_input_name_for_user" name="c[<?=$v->id ?>][name_for_user]" value="<?=$v->name_for_user ?>" /></span>
		</div>
	</td><?
}

if(is_row('sale_type'))
{
	?><td class="<?=((isset($v->sale_rules['percent']) && $v->sale_rules['percent'] > 0 && (!isset($v->sale_rules['type']) || empty($v->sale_rules['type']))) || (isset($v->sale_rules['type']) && $v->sale_rules['type'] == 'count')) ? 'cell--sale' : '' ?>">
		<span class="store_row_show"><?=isset($v->sale_rules['type']) && !empty($v->sale_rules['type']) ? $big_data['sale_rules'][$v->sale_rules['type']] : "Без правил" ?></span>
		<span class="store_row_edit">
			<select name="c[<?=$v->id ?>][sale_rules][type]" class="store_input_sale_type"><?
				
				foreach($big_data['sale_rules'] as $_k => $_v) 
				{
					?><option value="<?=$_k ?>"<?=isset($v->sale_rules['type']) && $v->sale_rules['type'] == $_k ? " selected" : ""?>><?=$_v ?></option><?
				}
			
			?></select>
		</span>
	</td><?
}

if(is_row('group'))
{
	?><td style="background:<?=xs_get_option('xs_store_'.$v->group_id.'_color') ?>">
		<span class="store_row_show"><?=$big_data["store_groups"][$v->group_id] ?></span>
		<span class="store_row_edit">
			<select name="c[<?=$v->id ?>][group_id]" class="store_input_group"><?
			
				foreach($big_data["store_groups"] as $_k => $_v)
				{
					?><option value="<?=$_k ?>"<?=$_k == $v->group_id ? " selected" : "" ?>><?=$_v ?></option><?
				}
				
			?></select>
		</span>
	</td><?
}

if(is_row('coefficient'))
{
	?><td style="background:<?=$coefficient['c'] ?>">
		<span><?=$coefficient['k'] ?></span>
	</td><?
}

if(is_row('days'))
{
	$_days_bg = '';
	if($v->days <= 1) $_days_bg = '#a5d6a7';
	elseif($v->days <= 3) $_days_bg = '#c8e6c9';
	elseif($v->days <= 7) $_days_bg = '#fff9c4';
	elseif($v->days <= 14) $_days_bg = '#ffcc80';
	else $_days_bg = '#ef9a9a';

	?><td class="cell--days" style="background:<?=$_days_bg?>">
		<span class="store_row_show"><?=$v->days?></span>
		<span class="store_row_edit"><input type="number" class="store_input_days" min="0" step="1" name="c[<?=$v->id ?>][days]" value="<?=$v->days ?>" /></span>
	</td><?
}

if(is_row('ms_quantity'))
{
	?><td class="<?=$v->ms_quantity > 0 ? 'cell--stock-ok' : 'cell--stock-zero'?>">
		<span><?=$v->ms_quantity ?></span>
	</td><?
}

if(is_row('purchase_price'))
{
	?><td>
		<span class="store_row_show"><?=number_format($v->purchase_price, 0, ',', ' ') ?> &#8381;</span>
		<span class="store_row_edit"><input type="number" class="store_input_purchase_price" min="0" step="1" name="c[<?=$v->id ?>][purchase_price]" value="<?=$v->purchase_price ?>" /></span>
	</td><?
}

if(is_row('original_price'))
{
	?><td>
