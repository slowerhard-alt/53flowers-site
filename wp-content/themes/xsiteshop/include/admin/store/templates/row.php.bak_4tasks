	</td><?
}

if(is_row('forced_price'))
{
	?><td class="<?=$v->forced_price > 0 ? 'cell--sale' : '' ?>">
		<span class="store_row_show"><?=$v->forced_price == 0 ? "" : (number_format($v->forced_price, 0, ',', ' ') . ' &#8381;') ?></span>
		<span class="store_row_edit"><input type="number" class="store_input_forced_price" min="0" step="0.01" name="c[<?=$v->id ?>][forced_price]" value="<?=$v->forced_price ?>" /><span class="store_hint_x2"><?=number_format(ceil($v->original_price * 2 / 5) * 5, 0, ',', ' ')?></span></span>
	</td><?
}

if(is_row('sale_percent'))
{
	?><td class="<?=(isset($v->sale_rules['percent']) && $v->sale_rules['percent'] > 0) ? 'cell--sale' : '' ?>">
		<span class="store_row_show"><?=isset($v->sale_rules['percent']) && $v->sale_rules['percent'] > 0 ? $v->sale_rules['percent']."%" : "" ?></span>
		<span class="store_row_edit"><input type="number" class="store_input_sale_percent" min="0" step="1" name="c[<?=$v->id ?>][sale_rules][percent]" value="<?=isset($v->sale_rules['percent']) ? $v->sale_rules['percent'] : "" ?>" /><span class="store_cell_clear" title="Очистить">×</span></span>
	</td><?
}

if(is_row('price'))
{
	?><td class="cell--price">
		<span><?=number_format($v->price, 0, ',', ' ') ?> &#8381;</span>
	</td><?
}

if(is_row('sale_price'))
{
	?><td class="<?=$v->sale_price > 0 ? 'cell--sale' : '' ?>">
		<span><?=$v->sale_price == 0 ? number_format($v->price, 0, ',', ' ').' &#8381;' : number_format($v->sale_price, 0, ',', ' ').' &#8381;' ?></span>
	</td><?
}

if(is_row('sale_forced_price'))
{
	?><td class="<?=$v->forced_price > 0 ? 'cell--sale' : '' ?>">
		<span><?
			
			if($v->forced_price != 0)
			{
				echo wc_price(
					(isset($v->sale_rules['percent']) && !empty($v->sale_rules['percent']) && $v->sale_rules['percent'] > 0 
						? $v->forced_price + $v->forced_price / 100 * $v->sale_rules['percent']
						: $v->forced_price
					), ['decimals' => 2]
				);
			}

		?></span>
	</td><?
}

if(is_row('is_set_forced_price'))
{
	?><td <?=!empty($v->color) && $v->color != "#ffffff" ? 'style="background:'.$v->color.'"' : '' ?>>
