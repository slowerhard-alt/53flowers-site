function add_group_components($arg = [])
{
	global $wpdb, $big_data;
	
	if(!isset($arg['name']) || empty($arg['name']))
	{
		return [
			'status' => 'error',
			'message' => "Не заполнено обязательно поле Название"
		];
	}
	
	$wpdb->query("
		INSERT INTO
			`xsite_store_groups`
		SET
			`name` = '".$wpdb->_real_escape($arg['name'])."',
			`sort` = '".(isset($arg['sort']) && is_numeric($arg['sort']) ? $arg['sort'] : 0)."'
	");
	
	if(!($insert_id = $wpdb->insert_id))
	{
		return [
			'status' => 'error',
			'message' => "Ошибка при создании группы"
		];
	}
	
	return [
		'status' => 'good',
		'message' => "Группа компонентов добавлена",
		'insert_id' => $insert_id
	];
}


// Получаем группу компонентов

function get_group_components($id)
{
	global $wpdb, $big_data;
	
	if(!is_numeric($id) || $id == 0)
		return false;
	
	$row = $wpdb->get_row($wpdb->prepare("
		SELECT 
			* 
		FROM 
			`xsite_store_groups`
		WHERE
			`id` = %d
	", $id));
	
	if(!$row)
		return false;
	
	$row->components = [];
	
	$db_components = $wpdb->get_results($wpdb->prepare("
		SELECT 
			c.* 
		FROM 
			`xsite_store_components_to_groups` cg
		INNER JOIN `xsite_store_components` c ON c.`id` = cg.`component_id`
		WHERE
		cg.`group_id` = %d
	", $id));
	
	if($db_components && is_array($db_components))
		foreach($db_components as $v)
			$row->components[$v->id] = $v;
			
	return $row;
}


