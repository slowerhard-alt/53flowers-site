// Получаем структуру категорий склада

function get_store_categories($id_name = false, $delimiter = " → ")
{
	global $wpdb;
	
	$db_categories = $wpdb->get_results("SELECT * FROM `xsite_store_categories` ORDER BY `sort`");
	
	foreach($db_categories as $v)
	{
		$v->fullname = get_store_categoriy_name($v->id, $delimiter);

		if($id_name)
			$divisions[$v->id] = $v->fullname;
		else
			$divisions[$v->id] = $v;
	}
	
	return $divisions;
}


// Выводим полное имя категории склада 

function get_store_categoriy_name($category_id, $delimiter = ', ')
{
	global $ar_store_categories, $wpdb;
	
	if(!isset($ar_store_categories) || count($ar_store_categories) == 0)
	{
		$_categories = $wpdb->get_results("SELECT * FROM `xsite_store_categories` ORDER BY `sort`");
		
		foreach($_categories as $v)
			$ar_store_categories[$v->id] = $v;
	}
	
	if(isset($ar_store_categories[$category_id]))
	{
		if($ar_store_categories[$category_id]->parent_id != $ar_store_categories[$category_id]->id && isset($ar_store_categories[$ar_store_categories[$category_id]->parent_id]))
		{
			return get_store_categoriy_name($ar_store_categories[$category_id]->parent_id, $delimiter).$delimiter.$ar_store_categories[$category_id]->name;
		}
		else
			return $ar_store_categories[$category_id]->name;
	}
	else
		return false;
}


// Получаем массив всех родительских категорий склада 

function get_store_categoriy_parents($category_id)
{
	global $ar_store_categories, $wpdb;
	
	if(!isset($ar_store_categories) || count($ar_store_categories) == 0)
	{
		$_categories = $wpdb->get_results("SELECT * FROM `xsite_store_categories` ORDER BY `sort`");
		
		foreach($_categories as $v)
			$ar_store_categories[$v->id] = $v;
	}
	
	if(isset($ar_store_categories[$category_id]))
	{
		if(isset($ar_store_categories[$ar_store_categories[$category_id]->parent_id]))
			return array_merge(get_store_categoriy_parents($ar_store_categories[$category_id]->parent_id), [$ar_store_categories[$category_id]]);
		else
			return [$ar_store_categories[$category_id]];
	}
	else
		return false;
}


// Получаем все дочерние катагории

function get_store_subcategories_all($parent_id = 0)
{
	global $wpdb, $ar_divisions;
	
	if(!isset($ar_divisions) || empty($ar_divisions) || !is_array($ar_divisions) || count($ar_divisions) == 0) 
		$ar_divisions = $wpdb->get_results("SELECT * FROM `xsite_store_categories` ORDER BY `sort`");
	
	if(!$ar_divisions)
		return false;
	
	foreach($ar_divisions as $v)
		if($v->parent_id == $parent_id)
		{
			$result[] = $v;
			$result = array_merge($result, get_store_subcategories_all($v->id));
		}
	
	return isset($result) && count($result) > 0 ? $result : array();
}


// Обновляем текущую цену и остатки компонента

function update_price_component($component_id = 0, $is_product_update = false, $is_send_telegram = false, $is_send_bitrix = false)
{
	global $wpdb, $big_data;
	
	$ar_set_prices = [];
	$component_id = (int)$component_id;
	$ar_set_components = [];
	
	$w = $component_id > 0
		? " WHERE `id` = '".$component_id."'"
		: "";
		
	if(!$db_component = $wpdb->get_results("SELECT * FROM `xsite_store_components`".$w))
		return false;
	
	foreach($db_component as $c)
	{
		$is_set_ms_price = false;
		
		$c->sale_rules = !empty($c->sale_rules)
			? json_decode($c->sale_rules, true)
			: [];
		
		if(isset($c->sale_rules['type']) && $c->sale_rules['type'] == 'count')
			$c->sale_percent = 0;
		else
			$c->sale_percent = isset($c->sale_rules['percent']) && !empty($c->sale_rules['percent'])
				? (int)$c->sale_rules['percent']
				: 0;
		
		$component_sale_price = 0;
		
		$coefficient = get_store_coefficient($c->group_id, $c->days);
		
		$_component_price = round($c->original_price * $coefficient['k'], 2);
		
		if($c->forced_price > 0)
		{
			if($c->is_set_forced_price == 'y')
			{
				$first_coefficient = get_store_coefficient($c->group_id, 1);
				$_component_sale_price = round($c->original_price * $first_coefficient['k'], 2);
				
				$sale_percent = $_component_sale_price != 0
					? $_component_price / $_component_sale_price * 100
					: 0;
				
				if($sale_percent > 0)
				{
					$component_sale_price = round($c->forced_price, 2);
					$component_price = round($component_sale_price/100*$sale_percent, 2);
				}
				else
				{
					$component_price = round($c->forced_price * $coefficient['k'], 2);
					$component_sale_price = 0;
				}
			}
			else
				$component_price = round($c->forced_price, 2);
		}
		else
			$component_price = $_component_price;
		
		if($c->sale_percent > 0)
			$component_sale_price = $component_price + ($component_price / 100 * $c->sale_percent);
		elseif($c->forced_price == 0)
		{
			$first_coefficient = get_store_coefficient($c->group_id, 1);
			
			if($coefficient['k'] != $first_coefficient['k'])
				$component_sale_price = round($c->original_price * $first_coefficient['k'], 2);
		}
		
		if($component_price >= $component_sale_price)
			$component_sale_price = 0;
		
		if($component_price != $c->price || $component_sale_price != $c->sale_price)
		{
			$wpdb->query("UPDATE 
					`xsite_store_components`
				SET 
					`price` = '".$component_price."', 
					`sale_price` = '".$component_sale_price."' 
				WHERE 
					`id` = '".$c->id."'
			"); 
			$ar_set_components[] = $c->id;
			
			$is_set_ms_price = true;
			
			if($component_price != $c->price)
				$ar_set_prices[] = $c->name." ".$component_price."р (".$c->price."р)";
		}
		elseif($is_product_update)
		{
			$ar_set_components[] = $c->id;
			$is_set_ms_price = true;
		}
		
		
		// Обновляем цену у товаров в МС
		
		if($is_set_ms_price && $c->ms_is_update_retail_price == 'y' && !empty($c->ms_ids))
		{
			$ms_components = json_decode($c->ms_components, true);
			
			if(is_array($ms_components))
			{
				if(!class_exists('MoySklad'))
					include $_SERVER['DOCUMENT_ROOT'].'/moysklad/class.php';
				
				$MoySklad = new MoySklad;
				
				foreach($ms_components as $v)
				{
					if(
						isset($v['id']) && 
						!empty(trim($v['id'])) && 
						isset($v['quantity']) && 
						$v['quantity'] > 0 && 
						(
							!isset($v['_price']) ||
							(float)$v['_price'] != (float)$component_price
						)
					)
						$MoySklad->update_price(trim($v['id']), $component_price);
				}
			}
		}
	}
	
	
	// Обновлем цену у товаров, которые содержать компонент
	
	$db_products = false;
	
	if($is_product_update && $component_id == 0)
		$db_products = $wpdb->get_results("SELECT `product_id` FROM `xsite_store_products` WHERE `site` = '53flowers'");
	elseif(count($ar_set_components))
		$db_products = $wpdb->get_results("SELECT `product_id` FROM `xsite_store_products` WHERE `component_id` IN ('".implode("','", $ar_set_components)."') AND `site` = '53flowers'");
	
	if($db_products)
	{
		$ar_products = [];
		
		foreach($db_products as $v)
			$ar_products[] = $v->product_id;
		
		$ar_products = array_unique($ar_products);
		
		foreach($ar_products as $v)
			set_product_price($v);
	}
		
		
	// Отправляем уведомления в TG и Б24
	
	if(count($ar_set_prices) > 0)
	{
		if($is_send_telegram)
		{
			message_to_telegram(implode("\n", $ar_set_prices).
				(is_user_logged_in() ? "\nЦены изменил: ".$big_data['current_user']->display_name : ""));
		}
		
		if($is_send_bitrix)
		{		
			if(!class_exists('bitrix24'))
				include $_SERVER['DOCUMENT_ROOT'].'/wp-content/themes/xsiteshop/include/class/bitrix24.php';

			$b24 = new bitrix24;

			$user_id = 5593;
			//$user_id = 90763;
			
			$b24->add_task([
				'TITLE' => "Замена цен ".date("d.m.Y H:i", strtotime('now') + (3600 * 3)),
				'DESCRIPTION' => implode("\n", $ar_set_prices).
					(is_user_logged_in() ? "\nЦены изменил: ".$big_data['current_user']->display_name : ""),
				'CREATED_BY' => $user_id,
				'DEADLINE' => date('Y-m-d H:i:s', strtotime('now') + (3600 * 7)),
				'GROUP_ID' => 79,
				'CHECKLIST' => [
					["TITLE" => 'Поменять цены на ФВ'],
					["TITLE" => 'Поменять цены на озон'],
					["TITLE" => 'Сгенерировать фид для вк и загрузить его в вк'],
					["TITLE" => 'Сгенерировать фид для ЯМ и обновить его в ЯМ'],
					["TITLE" => 'Сгенерировать фид для авито'],
					["TITLE" => 'Сгенерировать фид для Купера'],
				]
			], $user_id);
		}
	}
}


// Получаем значение коэффициента

global $ar_coefficient;

$ar_coefficient = [];

function get_store_coefficient($group_id, $days)
{
	global $ar_coefficient;
	
	if($group_id == 0)
		return ['k' => 1];
	
	if($days <= 3)
		$k = "0-3";
	elseif($days <= 6)
		$k = "4-6";
	elseif($days <= 10)
		$k = "7";
	else
		$k = "10";
	
	$k = "xs_store_".$group_id."_".$k;
	
	if(!isset($ar_coefficient[$k]) || empty($ar_coefficient[$k]))
		$ar_coefficient[$k] = ['k' => ((float)xs_get_option($k) ?: 1.0)];
	
	return $ar_coefficient[$k];
}


// Изменяем компоненты в составе товара

function set_store_products($product_id = 0, $component_id = 0, $quantity = 0, $name = "", $sale = 0, $is_markup = '', $is_set_stock_ms = '')
{
	global $big_data, $wpdb;
	
	if($product_id == 0 || $component_id == 0)
		return false;

	$quantity = round((float)$quantity, 1);
	$set = false;
	$sale = (int)$sale;
	
	if($is_markup != 'y')
		$is_markup = '';
	
	if($is_set_stock_ms != 'y')
		$is_set_stock_ms = '';
	
	if($d = $wpdb->get_row("SELECT * FROM `xsite_store_products` WHERE `product_id` = '".$product_id."' AND `component_id` = '".$component_id."' AND `site` = '53flowers'"))
	{
		if($quantity > 0 && ($d->quantity != $quantity || $d->name_in_product != $name || $d->sale_in_product != $sale || $d->is_markup != $is_markup || $d->is_set_stock_ms != $is_set_stock_ms))
		{
			$wpdb->query("
				UPDATE 
					`xsite_store_products` 
				SET 
					`quantity` = '".$quantity."', 
					`name_in_product` = '".$wpdb->_real_escape($name)."', 
					`sale_in_product` = '".$sale."', 
					`is_markup` = '".$is_markup."', 
					`is_set_stock_ms` = '".$is_set_stock_ms."' 
				WHERE 
					`product_id` = '".$product_id."' AND 
					`component_id` = '".$component_id."' AND
					`site` = '53flowers'
			");
			$set = true;
		}
		elseif($quantity == 0)
		{
			$wpdb->query("DELETE FROM `xsite_store_products` WHERE `product_id` = '".$product_id."' AND `component_id` = '".$component_id."' AND `site` = '53flowers'");
			$set = true;
		}
	}
	elseif($quantity > 0)
	{
		$wpdb->query("
			INSERT 
				INTO `xsite_store_products` 
			SET 
				`product_id` = '".$product_id."', 
				`component_id` = '".$component_id."', 
				`quantity` = '".$quantity."', 
				`name_in_product` = '".$wpdb->_real_escape($name)."',
				`sale_in_product` = '".$sale."',
				`is_markup` = '".$is_markup."',
				`is_set_stock_ms` = '".$is_set_stock_ms."',
				`site` = '53flowers'
		");
		$set = true;
	}
	
	// Пересчитываем цену товара
		
	if($set)
		set_product_price($product_id);
}


// Очищаем компоненты в составе товара

function clear_store_products($product_id)
{
	global $big_data, $wpdb;
	
	if($product_id == 0)
		return false;
	
	return $wpdb->query($wpdb->prepare("DELETE FROM `xsite_store_products` WHERE `product_id` = %d AND `site` = '53flowers'", $product_id));
}


// Изменяем компоненты в составе заказа

function set_store_orders($order_item_id = 0, $component_id = 0, $quantity = 0)
{
	global $big_data, $wpdb;
	
	if($order_item_id == 0 || $component_id == 0)
		return false;

	$quantity = round((float)$quantity, 1);
	$set = false;
	
	if($d = $wpdb->get_row("SELECT * FROM `xsite_store_orders` WHERE `order_item_id` = '".$order_item_id."' AND `component_id` = '".$component_id."'"))
	{
		if($quantity > 0 && $d->quantity != $quantity)
		{
			$wpdb->query("UPDATE `xsite_store_orders` SET `quantity` = '".$quantity."' WHERE `order_item_id` = '".$order_item_id."' AND `component_id` = '".$component_id."'");
			$set = true;
		}
		elseif($quantity == 0)
		{
			$wpdb->query("DELETE FROM `xsite_store_orders` WHERE `order_item_id` = '".$order_item_id."' AND `component_id` = '".$component_id."'");
			$set = true;
		}
		
		$order_id = $d->order_id;
	}
	elseif($quantity > 0)
	{
		$order_id = $wpdb->get_var("SELECT `order_id` FROM `xsite_wc_order_product_lookup` WHERE `order_item_id` = '".$order_item_id."'");
		$price = $wpdb->get_row("SELECT `price`, `original_price`, `sale_price` FROM `xsite_store_components` WHERE `id` = '".$component_id."'");
		
		$wpdb->query("
			INSERT INTO 
				`xsite_store_orders` 
			SET 
				`order_id` = '".$order_id."',
				`order_item_id` = '".$order_item_id."', 
				`component_id` = '".$component_id."', 
				`quantity` = '".$quantity."',
				`price` = '".$price->price."',
				`sale_price` = '".$price->sale_price."',
				`original_price` = '".$price->original_price."'
		");
		$set = true;
	}
}


