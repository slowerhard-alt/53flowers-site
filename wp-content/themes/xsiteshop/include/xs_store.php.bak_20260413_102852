// Получаем процент скидки для скидки от количества

function get_percent_for_sale_on_quantity($quantity)
{
	/*
	if($quantity >= 150)
		$percent = 30;
	else
	*/
	
	if($quantity >= 75)
		$percent = 25;
	elseif($quantity >= 50)
		$percent = 20;
	elseif($quantity >= 25)
		$percent = 15;
	elseif($quantity >= 15)
		$percent = 10;
	else
		$percent = 0;
	
	return $percent;
}


// Получаем компоненты, входящие в товар

function get_store_components_product($product_id = 0, $all = false, $order = "c.`sort`, c.`id`", $site = '53flowers')
{
	global $big_data, $wpdb;
	
	$result = [];
	
	if($product_id == 0)
		return $result;
	
	if(!$all)
	{
		$allowed_sites = ['53flowers', 'cvetyru-vn'];
		$site = in_array($site, $allowed_sites, true) ? $site : '53flowers';
		$db_store_products = $wpdb->get_results($wpdb->prepare("SELECT * FROM `xsite_store_products` WHERE `product_id` = %d AND `site` = %s", $product_id, $site));
	}
	else
	{
		$db_store_products = $wpdb->get_results($wpdb->prepare("
			SELECT 
				p.*,
				c.price,
				c.days,
				c.group_id,
				c.sale_price,
				c.purchase_price,
				c.original_price,
				c.name,
				c.name_for_user,
				c.sale_rules,
				c.image,
				c.favorite,
				c.show_in_product,
				c.hide_quantity_in_product,
				c.category_id,
				c.ms_quantity,
				c.ms_components,
				po.post_parent
			FROM 
				`xsite_store_products` AS p
			LEFT JOIN `xsite_store_components` AS c ON c.id = p.`component_id`
			LEFT JOIN `xsite_posts` AS po ON po.`ID` = p.`product_id`
			WHERE 
				p.`product_id` = %d AND
				p.`site` = %s
			ORDER BY
				c.`sort`, c.`id`
		", $product_id, $site));
		
		foreach($db_store_products as $k => $v)
		{
			$v->sale_rules = json_decode($v->sale_rules, true);
			$db_store_products[$k]->sale_rules = $v->sale_rules;
			$db_store_products[$k]->_sale_price = $db_store_products[$k]->sale_price;
			$db_store_products[$k]->_price = $db_store_products[$k]->price;
			$db_store_products[$k]->sale_on_quantity_percent = 0;
			
			if($v->sale_in_product > 0)
			{
				if($v->is_markup == 'y')
				{
					$db_store_products[$k]->sale_price = 0;
					$db_store_products[$k]->price = $db_store_products[$k]->price + ($db_store_products[$k]->price / 100 * $v->sale_in_product);
				}
				else
				{
					$db_store_products[$k]->sale_price = $db_store_products[$k]->price;
					$db_store_products[$k]->price = $db_store_products[$k]->price - ($db_store_products[$k]->price / 100 * $v->sale_in_product);
				}
			}
			elseif(isset($v->sale_rules['type']) && $v->sale_rules['type'] == 'count')
			{
				$min_quantity = isset($v->sale_rules['min_quantity'])
					? (int)$v->sale_rules['min_quantity']
					: 0;
					
				$min_days = isset($v->sale_rules['min_days'])
					? (int)$v->sale_rules['min_days']
					: 0;
					
				if($v->ms_quantity >= $min_quantity && $v->days >= $min_days)
				{
					if($percent = get_percent_for_sale_on_quantity($v->quantity))
					{
						if(get_post_meta(($v->post_parent ? $v->post_parent : $product_id), "is_sale_on_quantity", true) != 'y')
						{
							$db_store_products[$k]->sale_price = $db_store_products[$k]->price;
							$db_store_products[$k]->price = $db_store_products[$k]->price - ($db_store_products[$k]->price / 100 * $percent);
						}

						$db_store_products[$k]->sale_on_quantity_percent = $percent;
					}
				}
			}
			
			$db_store_products[$k]->ms_components = !empty($v->ms_components)
				? json_decode($v->ms_components, true)
				: [];
			
			if(count($db_store_products[$k]->ms_components))
				uasort($db_store_products[$k]->ms_components, 'get_store_components_ms_sort');
		}
	}
	
	foreach($db_store_products as $v)
		$result[$v->component_id] = $all ? $v : $v->quantity;
	
	return $result;
}


// Получаем компоненты, входящие в товар в заказе

function get_store_components_order($order_item_id = 0, $all = false)
{
	global $big_data, $wpdb;
	
	if($order_item_id == 0)
		return false;
	
	if(!$all)
		$db_store_products = $wpdb->get_results("SELECT * FROM `xsite_store_orders` WHERE `order_item_id` = '".$order_item_id."'");
	else
		$db_store_products = $wpdb->get_results("
			SELECT 
				o.*,
				c.price AS actual_component_price,
				c.sale_price AS actual_component_sale_price,
				c.original_price AS actual_component_original_price,
				c.name,
				c.sale_percent,
				c.image,
				c.favorite
			FROM 
				`xsite_store_orders` AS o
			LEFT JOIN `xsite_store_components` AS c ON c.id = o.`component_id`
			WHERE 
				o.`order_item_id` = '".$order_item_id."'
		");
	
	foreach($db_store_products as $v)
		$result[$v->component_id] = $all ? $v : $v->quantity;
	
	return $result;
}


// Устанавливаем цену товара

function set_product_price($product_id = 0)
{
	global $big_data, $wpdb;
	
	if($product_id == 0)
		return false;
		
	$price = 0;
	$markup = 0;
	$size_sale = 0;
	$stock = 'instock';
	$is_fresh_delivery = 'y';
	$is_sale_on_quantity = 0;
	
	if(!$db_store_products = $wpdb->get_results("
		SELECT 
			p.*,
			c.days,
			c.price,
			c.sale_price,
			c.sale_rules,
			c.is_fresh_delivery,
			c.ms_quantity
		FROM 
			`xsite_store_products` AS p
		LEFT JOIN `xsite_store_components` AS c ON c.`id` = p.`component_id`
		WHERE 
			p.`product_id` = '".$product_id."' AND
			p.`site` = '53flowers'
	"))
		return false;
	
	$parent_id = $wpdb->get_var("SELECT `post_parent` FROM `xsite_posts` WHERE `ID` = '".$product_id."'");
	$k = 0;
	
	if($sale_in_product = (int)$wpdb->get_var("SELECT `meta_value` FROM `xsite_postmeta` WHERE `post_id` = '".$product_id."' AND `meta_key` = 'sale_in_product'"))
		$is_markup = $wpdb->get_var("SELECT `meta_value` FROM `xsite_postmeta` WHERE `post_id` = '".$product_id."' AND `meta_key` = 'is_markup'");
	elseif($parent_id)
		if($sale_in_product = (int)$wpdb->get_var("SELECT `meta_value` FROM `xsite_postmeta` WHERE `post_id` = '".$parent_id."' AND `meta_key` = 'sale_in_product'"))
			$is_markup = $wpdb->get_var("SELECT `meta_value` FROM `xsite_postmeta` WHERE `post_id` = '".$parent_id."' AND `meta_key` = 'is_markup'");
	
	$_pid_for_sale_on_quantity = $parent_id ? $parent_id : $product_id;
	$_is_sale_on_quantity_disabled = ($wpdb->get_var($wpdb->prepare(
		"SELECT `meta_value` FROM `xsite_postmeta` WHERE `post_id` = %d AND `meta_key` = 'is_sale_on_quantity'",
		$_pid_for_sale_on_quantity
	)) == 'y');

	foreach($db_store_products as $v)
	{
		$v->sale_rules = json_decode($v->sale_rules, true);
		
		if($sale_in_product)
		{
			$v->sale_in_product = $sale_in_product;
			$v->is_markup = $is_markup;
		}
		
		if($v->sale_in_product > 0)
		{
			if($v->is_markup == 'y')
			{
				//$markup = $markup + ($v->price * $v->quantity);
				$price = $price + (($v->price * $v->quantity) + ($v->price * $v->quantity) / 100 * $v->sale_in_product);
			}
			else
			{
				$markup = $markup + ($v->price * $v->quantity);
				$price = $price + (($v->price * $v->quantity) - ($v->price * $v->quantity) / 100 * $v->sale_in_product);
			}
		}
		else
		{
			if(isset($v->sale_rules['type']) && $v->sale_rules['type'] == 'count')
			{
				$min_quantity = isset($v->sale_rules['min_quantity'])
					? (int)$v->sale_rules['min_quantity']
					: 0;
					
				$min_days = isset($v->sale_rules['min_days'])
					? (int)$v->sale_rules['min_days']
					: 0;
					
				if($v->ms_quantity >= $min_quantity && $v->days >= $min_days)
				{
					if(!$_is_sale_on_quantity_disabled)
					{
						if($percent = get_percent_for_sale_on_quantity($v->quantity))
						{
							$v->sale_price = $v->price;
							$v->price = $v->price - ($v->price / 100 * $percent);
						}
					}
					else
						$is_sale_on_quantity = $v->quantity;
				}
			}
				
			$price = $price + ($v->price * $v->quantity);
		
			if($v->sale_price == 0)
				$v->sale_price = $v->price;
			
			$markup = $markup + ($v->sale_price * $v->quantity);
		}
		
		if($v->is_set_stock_ms == 'y' && $v->ms_quantity < $v->quantity)
			$stock = 'outofstock';

		if($v->is_fresh_delivery == 'y')
		{
			$k++;
			
			if((int)$v->days > 2 || $stock == 'outofstock')
				$is_fresh_delivery = '';
		}
	}
	
	if($k == 0)
		$is_fresh_delivery = '';
	
	$price = ceil($price/5)*5;
	$markup = ceil($markup/5)*5;
	
	$sale_price = '';
	$regular_price = $price;
	
	if($markup > $price)
	{
		$sale_price = $price;
		$regular_price = $markup;
		$size_sale = $markup - $price;
	}
	elseif($is_sale_on_quantity) // Скидка на весь товар / вариацию, если нет других скидок и есть компонент со скидкой от количества
	{
		if($percent = get_percent_for_sale_on_quantity($is_sale_on_quantity))
		{
			$sale_price = ceil(($price - ($price / 100 * $percent))/5)*5;
			$price = $sale_price;
			$size_sale = $price - $sale_price;
		}
	}
	
	$result = [
		'_regular_price' => $regular_price,
		'_price' => $price,
		'_sale_price' => $sale_price,
		'_size_sale' => $size_sale,
		'_stock_status' => $stock,
		'_fresh_delivery' => $is_fresh_delivery,
	];
	
	$is_update = false;
	
	// Batch-fetch existing meta rows to avoid N+1 queries
	$_meta_keys = array_keys($result);
	$big_data['taboo_price'][$product_id] = $_meta_keys;
	$_keys_in = implode("','", $_meta_keys);
	$_existing_rows = $wpdb->get_results("SELECT * FROM `xsite_postmeta` WHERE `post_id` = '".$product_id."' AND `meta_key` IN ('".$_keys_in."')");
	$_existing_map = [];
	foreach($_existing_rows as $_row)
		$_existing_map[$_row->meta_key] = $_row;

	foreach($result as $k => $v)
	{
		if(isset($_existing_map[$k]))
		{
			$value = $_existing_map[$k];
			if($value->meta_value != $v)
			{
				$is_update = true;
				$wpdb->query("UPDATE `xsite_postmeta` SET `meta_value` = '".$v."' WHERE `meta_id` = '".$value->meta_id."'");
			}
				
			$wpdb->query("DELETE FROM `xsite_postmeta` WHERE `post_id` = '".$product_id."' AND `meta_key` = '".$k."' AND `meta_id` <> '".$value->meta_id."'");
		}
		else
		{
			$is_update = true;
			$wpdb->query("INSERT INTO `xsite_postmeta` SET `meta_value` = '".$v."', `post_id` = '".$product_id."', `meta_key` = '".$k."'");
		}
	}

	//$is_update = true; // ЗАКОММЕНТИРОВАТЬ

	if($is_update)
	{
		$arg = ['product_id' => $product_id, 'price' => $result['_price'], 'regular_price' => $result['_regular_price'], 'sale_price' => $result['_sale_price']];
		
		add_price_history($arg);
		
		if($value = $wpdb->get_row("SELECT * FROM `xsite_wc_product_meta_lookup` WHERE `product_id` = '".$product_id."'"))
		{
			$ar_set = [];
			
			if($value->stock_status != $result['_stock_status'])
				$ar_set[] = "`stock_status` = '".$result['_stock_status']."'";
			
			if($value->min_price != $result['_price'])
				$ar_set[] = "`min_price` = '".$result['_price']."'";
			
			if($value->max_price != $result['_price'])
				$ar_set[] = "`max_price` = '".$result['_price']."'";
			
			if(count($ar_set))
				$wpdb->query("UPDATE `xsite_wc_product_meta_lookup` SET ".implode(", ", $ar_set)." WHERE `product_id` = '".$product_id."'");
		}

	
		// Устанавливаем цену родительского товара (самая дешёвая вариация)
		
		if($parent_id)
		{
			$wpdb->query("DELETE FROM `xsite_store_products` WHERE `product_id` = '".$parent_id."' AND `site` = '53flowers'");
			
			$_size_sale = 0;
			$_stock = 'outofstock';
			$_is_fresh_delivery = 'y';
			$child_id = 0;
			
			$childrens = $wpdb->get_results("
				SELECT 
					p.`ID` 
				FROM 
					`xsite_posts` p
				WHERE 
					p.`post_parent` = '".$parent_id."' AND 
					p.`post_type` = 'product_variation' AND 
					p.`post_status` = 'publish' AND
					(SELECT pm.`meta_value` FROM `xsite_postmeta` pm WHERE pm.`post_id` = p.`ID` AND pm.`meta_key` = '_stock_status' LIMIT 1) = 'instock' 
			");
			
			foreach($childrens as $v)
			{
				$price = $wpdb->get_var("SELECT `meta_value` FROM `xsite_postmeta` WHERE `post_id` = '".$v->ID."' AND `meta_key` = '_price'");
				
				if(!isset($_price) || $price <= $_price)
				{
					$_price = $price;
					$child_id = $v->ID;
				}
				
				if(!isset($_max_price) || $price >= $_max_price)
					$_max_price = $price;
				
				/*
				if($_stock == 'outofstock')
				{
					if($wpdb->get_var("SELECT `meta_value` FROM `xsite_postmeta` WHERE `post_id` = '".$v->ID."' AND `meta_key` = '_stock_status'") == 'instock')
						$_stock = 'instock';
				}
				*/
				
				$_stock = 'instock';
				
				if($_is_fresh_delivery == 'y')
				{
					if($wpdb->get_var("SELECT `meta_value` FROM `xsite_postmeta` WHERE `post_id` = '".$v->ID."' AND `meta_key` = '_fresh_delivery'") != 'y')
						$_is_fresh_delivery = '';
				}
			}
			
			if($child_id)
			{
				$_regular_price = $wpdb->get_var("SELECT `meta_value` FROM `xsite_postmeta` WHERE `post_id` = '".$child_id."' AND `meta_key` = '_regular_price'");
				$_sale_price = $wpdb->get_var("SELECT `meta_value` FROM `xsite_postmeta` WHERE `post_id` = '".$child_id."' AND `meta_key` = '_sale_price'");
				$_size_sale = $wpdb->get_var("SELECT `meta_value` FROM `xsite_postmeta` WHERE `post_id` = '".$child_id."' AND `meta_key` = '_size_sale'");
			}
			
			$result = [
				'_regular_price' => $_regular_price,
				'_price' => $_price,
				'_sale_price' => $_sale_price,
				'_size_sale' => $_size_sale,
				'_stock_status' => $_stock,
				'_fresh_delivery' => $_is_fresh_delivery,
			];
			
			$is_parent_update = false;

			// Batch-fetch existing meta rows for parent to avoid N+1 queries
			$_parent_meta_keys = array_keys($result);
			$big_data['taboo_price'][$parent_id] = $_parent_meta_keys;
			$_parent_keys_in = implode("','", $_parent_meta_keys);
			$_parent_rows = $wpdb->get_results("SELECT * FROM `xsite_postmeta` WHERE `post_id` = '".$parent_id."' AND `meta_key` IN ('".$_parent_keys_in."')");
			$_parent_map = [];
			foreach($_parent_rows as $_prow)
				$_parent_map[$_prow->meta_key] = $_prow;

			foreach($result as $k => $v)
			{
				if(isset($_parent_map[$k]))
				{
					$value = $_parent_map[$k];
					if($value->meta_value != $v)
					{
						$wpdb->query("UPDATE `xsite_postmeta` SET `meta_value` = '".$v."' WHERE `meta_id` = '".$value->meta_id."'");
						$is_parent_update = true;
					}
					
					$wpdb->query("DELETE FROM `xsite_postmeta` WHERE `post_id` = '".$parent_id."' AND `meta_key` = '".$k."' AND `meta_id` <> '".$value->meta_id."'");
				}
				else
				{
					$wpdb->query("INSERT INTO `xsite_postmeta` SET `meta_value` = '".$v."', `post_id` = '".$parent_id."', `meta_key` = '".$k."'");
					$is_parent_update = true;
				}
			}
			
			//$is_parent_update = true; // ЗАКОММЕНТИРОВАТЬ
			
			if($is_parent_update)
			{
				$arg = ['product_id' => $parent_id, 'price' => $result['_price'], 'regular_price' => $result['_regular_price'], 'sale_price' => $result['_sale_price']];
				
				add_price_history($arg);
				
				if($value = $wpdb->get_row("SELECT * FROM `xsite_wc_product_meta_lookup` WHERE `product_id` = '".$parent_id."'"))
				{
					$ar_set = [];
					
					if($value->stock_status != $result['_stock_status'])
						$ar_set[] = "`stock_status` = '".$result['_stock_status']."'";
					
					if($value->min_price != $result['_price'])
						$ar_set[] = "`min_price` = '".$result['_price']."'";
					
					if($value->max_price != $result['_price'])
						$ar_set[] = "`max_price` = '".$_max_price."'";
					
					if(count($ar_set))
						$wpdb->query("UPDATE `xsite_wc_product_meta_lookup` SET ".implode(", ", $ar_set)." WHERE `product_id` = '".$parent_id."'");
				}
			}
		}
	}
	
	xs_clear_cache(false);
	
	return $price;
}


