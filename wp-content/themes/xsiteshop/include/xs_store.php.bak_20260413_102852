// Загружаем изображение с МС

function update_image_component_from_ms($ar_ms_image_ids)
{
	if(empty($ar_ms_image_ids))
		return false;
	
	if(!is_array($ar_ms_image_ids))
		$ar_ms_image_ids = [$ar_ms_image_ids];
	
	if(count($ar_ms_image_ids) == 0)
		return false;

	if(!class_exists('MoySklad'))
		include $_SERVER['DOCUMENT_ROOT'].'/moysklad/class.php';
		
	global $wpdb, $big_data;
	
	$MoySklad = new MoySklad;
	$moysklad_assortment = $MoySklad->get_assortment(array_unique($ar_ms_image_ids));

	if(is_array($moysklad_assortment))
	{
		foreach($moysklad_assortment as $v)
		{
			$image = "";
			
			if(isset($v['images']) && !empty($v['images']))
			{
				if($ms_image = $MoySklad->get_image($v['images']))
				{
					$path = $_SERVER['DOCUMENT_ROOT'].$big_data['component_image_path'].$ms_image['name'];
			
					if(!file_exists($path))
						file_put_contents($path, file_get_contents($ms_image['url']));
					
					$image = $ms_image['name'];
				}
				
				if(count($ar_ms_image_ids) > 1)
					usleep(200000);
			}
			
			$wpdb->query("
				UPDATE
					`xsite_store_components` 
				SET
					`image` = '".$image."'
				WHERE 
					`ms_image_id` = '".$v['code']."'
			");
		}
	}

}