function get_copy_links_html($post)
{
	if(!is_user_logged_in())
		return "";
	else
	{
		global $big_data;
		
		if(!isset($big_data['sizes']))
		{
			$sizes = get_terms(array(
				'taxonomy'		=> [], //['pa_kolichestvo', 'pa_razmer', 'pa_vysota'],
				'count'			=> false,
				'hide_empty'    => false,
			));
			
			foreach($sizes as $v)
				$big_data['sizes'][$v->slug] = $v;
		}
						
		$product = wc_get_product($post->ID);
		
		$ar_copy_all = [$post->post_title];
		
		if($product->product_type == "variable")
		{
			if($available_variations = $product->get_available_variations())
			{
				foreach($available_variations as $k => $v)
				{
					$variation_id = $v['variation_id'];
					$variable_product = new WC_Product_Variation($variation_id);
					
					if($price = $variable_product->get_price()) 
					{
						if(get_post_meta($variation_id, '_stock_status', true) == 'outofstock')
							continue;
						
						foreach($v['attributes'] as $_v)
						{
							$attr_code = $_v;
							break;
						}
						
						//$is_disabled = get_post_meta($variation_id, 'is_disabled', true) == 'yes';
						
						$regular_price = (int)$variable_product->get_regular_price();
						
						$percent = $regular_price > $price
							? (($p = round(100 - ($price / $regular_price * 100))) >= 5 ? $p."%" : 0)
							: 0;				
						
						$ar_copy_all[] = strip_tags($big_data['sizes'][$attr_code]->name." - ".str_replace(["&nbsp;", "&#8381;"], [" ", "₽"], wc_price($price)).($percent ? " (без скидки ".str_replace(["&nbsp;", "&#8381;"], [" ", "₽"], wc_price($regular_price)).")" : ""));
					}
				}
			}
		}
		
		return '<div class="xs_copy_text__container">
				<div class="xs_copy_text xs_copy_text--name" title="Скопировать название товара" onclick="xs_copy(\''.htmlspecialchars($post->post_title).'\')">'.get_svg('copy-name', "", "text").'</div>
				<div class="xs_copy_text xs_copy_text--link" title="Скопировать ссылку на товар" onclick="xs_copy(\''.get_permalink($post->ID).'\')">'.get_svg('copy-link', "", "text").'</div>
				<div class="xs_copy_text xs_copy_text--namelink" title="Скопировать название и ссылку на товар" onclick="xs_copy(\''.htmlspecialchars($post->post_title).' - '.get_permalink($post->ID).'\')">'.get_svg('copy-namelink', "", "text").'</div>
				<div class="xs_copy_text xs_copy_text--all" title="Скопировать название и вариации с ценами" onclick="xs_copy(\''.htmlspecialchars(implode("\\n", $ar_copy_all)).'\')">'.get_svg('copy-all', "", "text").'</div>
			</div>';
	}
}

// Получаем состав букета

function get_structure_for_product($product_id, $show_admin = true)
{
	global $wpdb;
	
	$set_status_html = $show_admin
		? get_set_status_html($post)
		: "";
		
	$parent_id = (int)$wpdb->get_var("SELECT `post_parent` FROM `xsite_posts` WHERE `ID` = '".$product_id."'");
	$post = $wpdb->get_row("SELECT * FROM `xsite_posts` WHERE `ID` = '".($parent_id ? $parent_id : $product_id)."'");
	
	$copy_links_html = $show_admin
		? get_copy_links_html($post)
		: "";
	
	if(!$components = get_store_components_product($product_id, true))
		return $set_status_html.$copy_links_html;
	
	foreach($components as $k => $v)
	{
		if($ar_parents_categories = get_store_categoriy_parents($v->category_id))
		{
			foreach($ar_parents_categories as $_v)
			{
				if($_v->parent_id == 0)
				{
					$components[$k]->category_id = $_v->id;
					$components[$k]->sort = $_v->sort;
					
					break;
				}
			}
		}
	}
	
	uasort($components, function($a, $b)
	{
		return ($a->sort > $b->sort);
	});

	$result = "";

	if($show_admin)
	{
		$is_admin = is_user_logged_in();
		
		if($is_admin)
		{
			$result .= '<p class="xs_admin_structure_product__head">
				<span class="xs_admin_structure_product__head-title">Компоненты:</span>
				<span class="xs_admin_structure_product__head-ms" data-id="'.$product_id.'" data-step="1">
					<span>Мой склад</span>
				</span>
			</p>';
			
			$ar_items = [];
			$purchase_price = 0;
			$total_price = 0;
			
			foreach($components as $v)
			{
				if(isset($preview_category) && $preview_category != $v->category_id)
					$ar_items[] = '<div class="xs_admin_structure_product__delimiter"></div>';
				
				$ar_items[] = '<div class="xs_admin_structure_product__item" data-category_id="'.$v->category_id.'">
					<a href="/wp-admin/admin.php?page=store&section=detail&id='.$v->component_id.'" target="_blank" class="xs_admin_structure_product__item-name">'.$v->name.'</a>
					<div class="xs_admin_structure_product__item-quantity">'.$v->quantity.'&nbsp;шт</div>
					<div class="xs_admin_structure_product__item-price">по '.$v->price.'&nbsp;₽</div>
					<div class="xs_admin_structure_product__item-total">('.($v->price * $v->quantity).'&nbsp;₽)</div>
				</div>';
				
				if(count($v->ms_components))
				{
					$ar_items[] = '<div class="xs_admin_structure_product__ms-items">';
					
					foreach($v->ms_components as $_v)
					{
						$quantity_status = 'not_found';
						
						if($_v['quantity'] >= $v->quantity)
							$quantity_status = 'instock';
						elseif($_v['quantity'] > 0)
							$quantity_status = 'outofstock';
						
						$ar_items[] = '<div class="xs_admin_structure_product__ms-item '.$quantity_status.'">
							<div class="xs_admin_structure_product__ms-item-name">'.$_v['name'].'</div>
							<div class="xs_admin_structure_product__ms-item-days">'.$_v['days'].'&nbsp;дн</div>
							<div class="xs_admin_structure_product__ms-item-quantity">'.$_v['quantity'].'&nbsp;шт</div>
							<div class="xs_admin_structure_product__ms-item-price">'.$_v['price'].'&nbsp;₽</div>
						</div>';
					}
					
					$ar_items[] = '</div>';
				}
				
				$preview_category = $v->category_id;
				
				$purchase_price = ($v->purchase_price > 0)
					? $purchase_price + ($v->purchase_price * $v->quantity)
					: $purchase_price + ($v->original_price * $v->quantity);
					
				$total_price = $total_price + ($v->price * $v->quantity);
			}
			
			$ar_items[] = '<div class="xs_admin_structure_product__delimiter"></div>';
			
			$result .= '<div class="xs_admin_structure_product">
				'.implode("", $ar_items).'
				<!--p>Маржа: '.wc_price($total_price - $purchase_price).'</p-->
			</div>
			<a href="/wp-content/themes/xsiteshop/load/xs_form_set_structure.php?product_id='.$product_id.'" data-type="ajax" class="btn fancybox">Изменить состав</a>
			&nbsp;&nbsp;<a href="/wp-admin/admin.php?page=calculate&product_id='.$product_id.'" target="_blank" class="btn btn--empty">Калькулятор</a>'
			.$set_status_html.$copy_links_html.'
			<p>&nbsp;</p>';
		}
	}

	if(get_post_meta(($parent_id > 0 ? $parent_id : $product_id), "hide_structure", true) != 'y')
	{
		$ar_items = [];
		
		foreach($components as $v)
		{
			if($v->show_in_product == 'y')
			{
				if(!empty($v->name_in_product))
					$name = $v->name_in_product;
				elseif(!empty($v->name_for_user))
					$name = $v->name_for_user;
				else
					$name = $v->name;
				
				if($v->hide_quantity_in_product == 'y')
					$v->quantity = 0;
				
				$ar_items[$name] = isset($ar_items[$name])
					? $v->quantity + $ar_items[$name] 
					: $v->quantity;
			}
		}
		
		if(count($ar_items))
		{
			$_ar_items = [];
			
			foreach($ar_items as $k => $v)
				$_ar_items[] = $k.($v > 0 ? " – ".$v." шт" : "");
		
			$result .= "<p>Состав: ".implode(", ", $_ar_items).".</p>";
		}
	}
	
	return $result;
}


// Актуализируем описание товара, добавляем состав при необходимости

function insert_structure_in_content($post_content, $structure_html)
{
	$unique_start = '<div class="_system_structure_text">';
	$unique_end = '</div>';
	
	$_post_content = $post_content;
	
	preg_match('/'.preg_quote($unique_start,'/').'(.*)'.preg_quote($unique_end, '/').'/Us', $post_content, $match);
	
	if(empty($structure_html))
		$_post_content = str_replace($match[1], '', $post_content);
	else
	{
		if(!empty($match[1]))
		{
			if(trim(strip_tags($match[1])) != trim(strip_tags($structure_html)))
				$_post_content = str_replace($match[1], $structure_html, $post_content);
		}
		else
			$_post_content = trim($unique_start.$structure_html.$unique_end." ".$post_content);
	}

	return trim($_post_content);
}

function actual_product_content($post)
{
	global $wpdb;
	
	$is_set = false;
	
	if(is_numeric($post))
		$post = $wpdb->get_row("SELECT * FROM `xsite_posts` WHERE `ID` = '".$post."' AND `post_type` = 'product'");
	
	if($post->post_parent == 0)
	{
		$variations = $wpdb->get_results("SELECT * FROM `xsite_posts` WHERE `post_parent` = '".$post->ID."' AND `post_type` = 'product_variation'");
		
		if($variations)
		{
			foreach($variations as $variation)
			{
				$structure_html = get_structure_for_product($variation->ID, false);
				$post_content = get_post_meta($variation->ID, '_variation_description', true);
				
				$_post_content = insert_structure_in_content($post->post_content, '');
				$_post_content = insert_structure_in_content($_post_content, $structure_html);
				
				if($_post_content != $post_content)
				{
					update_post_meta($variation->ID, '_variation_description', $_post_content);
					$is_set = true;
				}
			}
		}
	}
	
	$structure_html = get_structure_for_product($post->ID, false);
	$_post_content = insert_structure_in_content($post->post_content, $structure_html);
	
	if($_post_content != $post->post_content)
		$is_set = true;

	if($is_set)
	{
		$my_post = [
			'ID' => $post->ID,
			'post_content' => $_post_content,
		];

		wp_update_post(wp_slash($my_post));
	}
}


